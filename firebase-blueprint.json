{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the platform",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation time" }
      },
      "required": ["uid", "email", "role"]
    },
    "listing": {
      "title": "Property Listing",
      "description": "A public property listing or requirement",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Listing title" },
        "description": { "type": "string", "description": "Property description" },
        "type": { "type": "string", "enum": ["buy", "sell", "rent", "lease"], "description": "Type of listing" },
        "propertyType": { "type": "string", "enum": ["plot", "residential", "commercial", "agricultural"], "description": "Category of property" },
        "price": { "type": "string", "description": "Price or budget" },
        "location": { "type": "string", "description": "Property location" },
        "imageUrl": { "type": "string", "description": "URL of the property image" },
        "ownerId": { "type": "string", "description": "UID of the poster" },
        "status": { "type": "string", "enum": ["pending", "approved", "sold", "rejected"], "description": "Listing status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation time" }
      },
      "required": ["title", "type", "ownerId", "status"]
    },
    "listing_private": {
      "title": "Private Listing Details",
      "description": "Sensitive contact information for a listing",
      "type": "object",
      "properties": {
        "listingId": { "type": "string", "description": "ID of the associated public listing" },
        "contactName": { "type": "string", "description": "Full name of the contact person" },
        "contactPhone": { "type": "string", "description": "Phone number" },
        "contactEmail": { "type": "string", "format": "email", "description": "Email address" },
        "ownerId": { "type": "string", "description": "UID of the poster" }
      },
      "required": ["listingId", "contactName", "contactPhone", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles"
    },
    "/listings/{listingId}": {
      "schema": "listing",
      "description": "Public property listings"
    },
    "/listings_private/{listingId}": {
      "schema": "listing_private",
      "description": "Private contact details for listings"
    }
  }
}
